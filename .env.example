# ============================================================
# Mayur Electronics — Environment Variables (EXAMPLE)
# Copy to .env.local for local dev. In Vercel, add each of these
# under Project → Settings → Environment Variables.
# Do NOT put real secrets in this file — it is committed to git.
# ============================================================

# ---- Supabase (REQUIRED) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server-only. Used by API routes / admin actions. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Cloudinary (for image uploads) ----
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
# Optional server-side Cloudinary (not needed for unsigned upload):
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Razorpay (for online payments; leave placeholders to use COD only) ----
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ---- Business / WhatsApp ----
# International format, digits only (no + or spaces), e.g. 919829266287
NEXT_PUBLIC_WHATSAPP_NUMBER=919829266287
# Your live domain once deployed, e.g. https://mayur-electronics.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Google Maps / Location (optional — About section) ----
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...
# NEXT_PUBLIC_GOOGLE_MAPS_DIRECTIONS_URL=https://maps.app.goo.gl/xxxxxxxx
# NEXT_PUBLIC_BUSINESS_PHONE=+91 98292 66287

# ---- Debug (optional) ----
# SUPABASE_DEBUG_AUTH=true
